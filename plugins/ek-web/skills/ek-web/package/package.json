{
  "name": "@ekdesign/web",
  "version": "0.2.1",
  "description": "ek-design tokens for web consumers \u2014 Tailwind v4 (default), legacy Tailwind v3, shadcn/ui theme, flat CSS variables. Generated from design-model.yaml. Brand thesis: Dark Ledger / Neon Operator. Principle: Purple is the world. Magenta is the command. Cyan is the proof.",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "Eric Kazmaier",
    "url": "https://github.com/ejkaz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ejkaz/ek-design.git",
    "directory": "plugins/ek-web/skills/ek-web/package"
  },
  "homepage": "https://github.com/ejkaz/ek-design#readme",
  "bugs": {
    "url": "https://github.com/ejkaz/ek-design/issues"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "tailwind",
    "tailwind-v4",
    "shadcn",
    "css-variables",
    "cyberpunk",
    "ek-design"
  ],
  "files": [
    "dist/*.css",
    "dist/*.ts",
    "README.md",
    "LICENSE"
  ],
